generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Level {
  BLOCKS
  CODE
  PRO
}

enum Status {
  WAITING
  CODING
  BATTLE
  DONE
}

model Admin {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  sessions  Session[]
  createdAt DateTime  @default(now())
}

// ─── User accounts ────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  username         String   @unique
  displayName      String
  passwordHash     String
  bio              String?  @db.Text
  avatar           String   @default("🤖") @db.Text
  preferredLang    String   @default("js")
  preferredSkin    String   @default("robot")
  experienceLevel  String   @default("beginner")
  programmingYears Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  currentStreak  Int      @default(0)
  bestStreak     Int      @default(0)
  totalXp        Int      @default(0)
  totalWins      Int      @default(0)
  totalBattles   Int      @default(0)
  lastWinDate    String   @default("")
  elo            Int      @default(1000)

  // Password reset
  passwordResetToken  String?
  passwordResetExpiry DateTime?

  players      Player[]
  applications TournamentApplication[]

  // Phase 2 relations
  eloHistory         EloHistory[]
  seasonRanks        SeasonRank[]
  notifications      Notification[]
  challengesSent     Challenge[]    @relation("ChallengeFrom")
  challengesReceived Challenge[]    @relation("ChallengeTo")

  // Phase 4 clan relations
  clanOwned    Clan?       @relation("ClanOwner")
  clanMember   ClanMember?
  clanMessages ClanMessage[]
}

model Session {
  id          String   @id @default(cuid())
  adminId     String?
  name        String
  level       Level    @default(CODE)
  lang        String?
  format      String   @default("bo3")
  timeLimit   Int      @default(10)
  code1       String   @unique
  code2       String   @unique
  allowedSkins String[] @default(["robot", "gladiator", "boxer", "cosmonaut"])
  status      Status   @default(WAITING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  admin       Admin?   @relation(fields: [adminId], references: [id])
  players     Player[]
  battles     Battle[]
  tournamentMatch TournamentMatch?
}

model Player {
  id        String   @id @default(cuid())
  sessionId String
  slot      Int
  name      String
  skin      String
  lang      String?
  code      String?  @db.Text
  strategy  Json?
  userId    String?
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@unique([sessionId, slot])
}

model Battle {
  id        String   @id @default(cuid())
  sessionId String
  round     Int
  winner    Int
  hp1Final  Int
  hp2Final  Int
  log       Json
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
}

// ─── Tournament system ────────────────────────────────────────────────────────

enum TournamentStatus {
  DRAFT
  REGISTRATION
  CLOSED
  ACTIVE
  DONE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MatchStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  DONE
}

model Tournament {
  id                   String            @id @default(cuid())
  name                 String
  description          String?           @db.Text
  startDate            DateTime
  registrationDeadline DateTime
  bracketGeneratedAt   DateTime?
  maxParticipants      Int               @default(16)
  status               TournamentStatus  @default(DRAFT)
  format               String            @default("bo3")
  level                Level             @default(CODE)
  createdAt            DateTime          @default(now())

  // Phase 4: bracket type + prizes + recurring
  bracketType          String            @default("SINGLE_ELIMINATION") // SINGLE_ELIMINATION | DOUBLE_ELIMINATION | ROUND_ROBIN
  prizeXp              Int               @default(0)     // XP for 1st place
  prizeSkin            String?                           // skin unlocked for winner
  isRecurring          Boolean           @default(false)
  recurringInterval    String?                           // "weekly" | "monthly"
  parentTournamentId   String?                           // if created from recurring template

  applications         TournamentApplication[]
  matches              TournamentMatch[]
}

model TournamentApplication {
  id               String            @id @default(cuid())
  tournamentId     String
  tournament       Tournament        @relation(fields: [tournamentId], references: [id])

  playerName       String
  playerEmail      String
  experienceLevel  String            @default("beginner")
  programmingYears Int               @default(0)
  preferredLang    String            @default("js")
  about            String?           @db.Text

  status           ApplicationStatus @default(PENDING)
  skillScore       Float?
  adminNote        String?
  seed             Int?

  userId           String?
  user             User?             @relation(fields: [userId], references: [id])
  createdAt        DateTime          @default(now())

  matchesAsP1      TournamentMatch[] @relation("Match_P1")
  matchesAsP2      TournamentMatch[] @relation("Match_P2")
  wonMatches       TournamentMatch[] @relation("Match_Winner")

  @@unique([tournamentId, playerEmail])
}

model TournamentMatch {
  id           String                  @id @default(cuid())
  tournamentId String
  tournament   Tournament              @relation(fields: [tournamentId], references: [id])

  round        Int
  position     Int

  p1Id         String?
  p2Id         String?
  p1           TournamentApplication?  @relation("Match_P1", fields: [p1Id], references: [id])
  p2           TournamentApplication?  @relation("Match_P2", fields: [p2Id], references: [id])

  winnerId     String?
  winner       TournamentApplication?  @relation("Match_Winner", fields: [winnerId], references: [id])

  sessionId    String?                 @unique
  session      Session?                @relation(fields: [sessionId], references: [id])
  status       MatchStatus             @default(PENDING)
  scheduledAt  DateTime?

  // Phase 4: double elimination bracket tracking
  bracket      String                  @default("W") // W = winners, L = losers, GF = grand final

  createdAt    DateTime                @default(now())

  @@unique([tournamentId, round, position, bracket])
}

// ─── Phase 2: ELO History ─────────────────────────────────────────────────────

model EloHistory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  elo        Int      // ELO after this match
  delta      Int      // change (+/-)
  won        Boolean
  sessionId  String?
  opponentId String?  // opponent userId (for display)
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

// ─── Phase 2: Seasons ─────────────────────────────────────────────────────────

model Season {
  id        String     @id @default(cuid())
  name      String
  number    Int        @unique
  startDate DateTime
  endDate   DateTime
  isActive  Boolean    @default(false)
  createdAt DateTime   @default(now())

  ranks     SeasonRank[]
}

model SeasonRank {
  id        String   @id @default(cuid())
  seasonId  String
  season    Season   @relation(fields: [seasonId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  elo       Int
  rank      Int

  @@unique([seasonId, userId])
}

// ─── Phase 2: Notifications ───────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // challenge_received | challenge_accepted | challenge_declined | match_found | season_end
  payload   Json     @default("{}")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

// ─── Phase 2: Challenges ──────────────────────────────────────────────────────

model Challenge {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  fromUser   User     @relation("ChallengeFrom", fields: [fromUserId], references: [id])
  toUser     User     @relation("ChallengeTo",   fields: [toUserId],   references: [id])

  status     String   @default("PENDING")  // PENDING | ACCEPTED | DECLINED | EXPIRED | DONE
  sessionId  String?  @unique
  skin       String   @default("robot")
  lang       String   @default("auto")
  message    String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

// ─── Phase 4: Clan system ─────────────────────────────────────────────────────

model Clan {
  id          String   @id @default(cuid())
  name        String   @unique
  tag         String   @unique  // [TAG] 2-5 chars uppercase
  description String?  @db.Text
  avatar      String   @default("⚔️")
  elo         Int      @default(1000)
  ownerId     String   @unique
  totalWins   Int      @default(0)
  totalWars   Int      @default(0)
  createdAt   DateTime @default(now())

  owner    User         @relation("ClanOwner", fields: [ownerId], references: [id])
  members  ClanMember[]
  messages ClanMessage[]
  wars1    ClanWar[]    @relation("ClanWar1")
  wars2    ClanWar[]    @relation("ClanWar2")
}

model ClanMember {
  id       String   @id @default(cuid())
  clanId   String
  userId   String   @unique
  role     String   @default("MEMBER")  // OWNER | OFFICER | MEMBER
  joinedAt DateTime @default(now())

  clan Clan @relation(fields: [clanId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([clanId, userId])
}

model ClanMessage {
  id        String   @id @default(cuid())
  clanId    String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  clan Clan @relation(fields: [clanId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([clanId, createdAt])
}

model ClanWar {
  id         String   @id @default(cuid())
  clan1Id    String
  clan2Id    String
  status     String   @default("PENDING")  // PENDING | ACTIVE | DONE
  winnerId   String?
  clan1Score Int      @default(0)
  clan2Score Int      @default(0)
  startDate  DateTime
  endDate    DateTime
  createdAt  DateTime @default(now())

  clan1 Clan @relation("ClanWar1", fields: [clan1Id], references: [id])
  clan2 Clan @relation("ClanWar2", fields: [clan2Id], references: [id])
}
