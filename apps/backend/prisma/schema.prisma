generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Level {
  BLOCKS
  CODE
  PRO
}

enum Status {
  WAITING
  CODING
  BATTLE
  DONE
}

model Admin {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  sessions  Session[]
  createdAt DateTime  @default(now())
}

// ─── User accounts ────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  username         String   @unique
  displayName      String
  passwordHash     String
  bio              String?  @db.Text
  avatar           String   @default("🤖")
  preferredLang    String   @default("js")
  preferredSkin    String   @default("robot")
  experienceLevel  String   @default("beginner")
  programmingYears Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  players      Player[]
  applications TournamentApplication[]
}

model Session {
  id          String   @id @default(cuid())
  adminId     String
  name        String
  level       Level    @default(CODE)
  lang        String?
  format      String   @default("bo3")
  timeLimit   Int      @default(10)
  code1       String   @unique
  code2       String   @unique
  allowedSkins String[] @default(["robot", "gladiator", "boxer", "cosmonaut"])
  status      Status   @default(WAITING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  admin       Admin    @relation(fields: [adminId], references: [id])
  players     Player[]
  battles     Battle[]
}

model Player {
  id        String   @id @default(cuid())
  sessionId String
  slot      Int
  name      String
  skin      String
  lang      String?
  code      String?  @db.Text
  strategy  Json?
  userId    String?
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@unique([sessionId, slot])
}

model Battle {
  id        String   @id @default(cuid())
  sessionId String
  round     Int
  winner    Int
  hp1Final  Int
  hp2Final  Int
  log       Json
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
}

// ─── Tournament system ────────────────────────────────────────────────────────

enum TournamentStatus {
  DRAFT
  REGISTRATION
  CLOSED
  ACTIVE
  DONE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MatchStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  DONE
}

model Tournament {
  id                   String            @id @default(cuid())
  name                 String
  description          String?           @db.Text
  startDate            DateTime
  registrationDeadline DateTime
  bracketGeneratedAt   DateTime?
  maxParticipants      Int               @default(16)
  status               TournamentStatus  @default(DRAFT)
  format               String            @default("bo3")
  level                Level             @default(CODE)
  createdAt            DateTime          @default(now())

  applications         TournamentApplication[]
  matches              TournamentMatch[]
}

model TournamentApplication {
  id               String            @id @default(cuid())
  tournamentId     String
  tournament       Tournament        @relation(fields: [tournamentId], references: [id])

  playerName       String
  playerEmail      String
  experienceLevel  String            @default("beginner")
  programmingYears Int               @default(0)
  preferredLang    String            @default("js")
  about            String?           @db.Text

  status           ApplicationStatus @default(PENDING)
  skillScore       Float?
  adminNote        String?
  seed             Int?

  userId           String?
  user             User?             @relation(fields: [userId], references: [id])
  createdAt        DateTime          @default(now())

  matchesAsP1      TournamentMatch[] @relation("Match_P1")
  matchesAsP2      TournamentMatch[] @relation("Match_P2")
  wonMatches       TournamentMatch[] @relation("Match_Winner")

  @@unique([tournamentId, playerEmail])
}

model TournamentMatch {
  id           String                  @id @default(cuid())
  tournamentId String
  tournament   Tournament              @relation(fields: [tournamentId], references: [id])

  round        Int
  position     Int

  p1Id         String?
  p2Id         String?
  p1           TournamentApplication?  @relation("Match_P1", fields: [p1Id], references: [id])
  p2           TournamentApplication?  @relation("Match_P2", fields: [p2Id], references: [id])

  winnerId     String?
  winner       TournamentApplication?  @relation("Match_Winner", fields: [winnerId], references: [id])

  sessionId    String?
  status       MatchStatus             @default(PENDING)
  scheduledAt  DateTime?

  createdAt    DateTime                @default(now())

  @@unique([tournamentId, round, position])
}
